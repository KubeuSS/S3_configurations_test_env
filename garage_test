#!/bin/bash
set -e

IP_FILE="nodes_ips.txt"
CREDS_FILE="garage_credentials.env"
OBJ_SIZE="256KiB"
OBJECTS=50
DURATION="60s"
CONCURRENT=8
BENCHDATA="eksperyment_garage_01"

if [ ! -f "$CREDS_FILE" ]; then
    echo "[!!] Brak $CREDS_FILE — uruchom najpierw ./garage_deploy.sh" >&2
    exit 1
fi
source "$CREDS_FILE"

read -r FIRST_VM FIRST_IP < "$IP_FILE"
HOST="${FIRST_IP}:3900"

while read -r VM_NAME VM_IP; do
    multipass exec "$VM_NAME" -- bash -c "sync && echo 3 | sudo tee /proc/sys/vm/drop_caches" < /dev/null > /dev/null
done < "$IP_FILE"

echo "benchmarkowanie Garage..."
warp mixed \
  --host="$HOST" \
  --access-key="$GARAGE_ACCESS_KEY" \
  --secret-key="$GARAGE_SECRET_KEY" \
  --region=garage \
  --obj.size "$OBJ_SIZE" \
  --objects "$OBJECTS" \
  --duration "$DURATION" \
  --concurrent "$CONCURRENT" \
  --benchdata "$BENCHDATA" --no-color > /tmp/warp_garage_out.txt 2>&1

grep -vE "WARP|MinIO|λ" /tmp/warp_garage_out.txt
